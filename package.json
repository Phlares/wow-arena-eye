{
  "name": "wow-arena-eye",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "setup": "node scripts/setup.mjs",
"test": "vitest run",
    "test:watch": "vitest",
    "ingest": "tsx src/cli/ingest.ts",
    "view": "tsx src/cli/view.ts",
    "build-occupancy": "tsx scripts/build-occupancy.mjs",
    "view-occupancy": "node scripts/view-occupancy.mjs",
    "ingest-db": "node --experimental-sqlite --import tsx src/cli/ingest-db.ts",
    "scorecard": "node --experimental-sqlite --import tsx src/cli/scorecard.ts",
    "viewer": "npm run build --prefix web && node --experimental-sqlite --import tsx src/viewer/server.ts",
    "viewer:dev": "node scripts/viewer-dev.mjs",
    "extract-fixture": "tsx src/util/extractMatchFixture.ts"
  },
  "dependencies": {
    "@wowarenalogs/parser": "file:./vendor/parser-proxy",
    "rxjs": "^6.6.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
