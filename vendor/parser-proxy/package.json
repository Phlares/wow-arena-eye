{
  "name": "@wowarenalogs/parser",
  "version": "6.0.0",
  "description": "Proxy package pointing to the built dist from the wowarenalogs submodule. No devDependencies to avoid registry fetches for private packages.",
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "eventemitter3": "^4.0.7",
    "line-reader": "^0.4.0",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "md5": "^2.3.0",
    "moment-timezone": "^0.5.39",
    "rxjs": "^6.6.6"
  }
}
